\DeclareFloatingEnvironment[fileext=lol,placement=tbp,within=none]{listing}

\ifthenelse{\equal{\LanguageOption}{portuguese}}{%
    \SetupFloatingEnvironment{listing}{name=Listagem,within=none}
}{\ifthenelse{\equal{\LanguageOption}{spanish}}{%
    \SetupFloatingEnvironment{listing}{name=Listado,within=none}
}{%
    \SetupFloatingEnvironment{listing}{name=Listing,within=none}
}}
\captionsetup[listing]{position=above,skip=6pt}

\lstset{
    frame=lines,
    aboveskip=3mm,
    belowskip=3mm,
    showstringspaces=false,
    columns=flexible,
    basicstyle={\small\ttfamily},
    numbers=left,
    numberstyle=\tiny\color{gray},
    keywordstyle=\color{blue},
    commentstyle=\color{gray},
    stringstyle=\color{green},
    breaklines=true,
    breakatwhitespace=true,
    tabsize=4
}

% Define the 'code' environment using listings
\lstnewenvironment{code}[1][]
{
    \captionsetup{type=listing}
    \lstset{#1}
}
{}

% Define the 'longlisting' environment using listings
\lstnewenvironment{longlisting}[1][]
{
    \captionsetup{type=listing}
    \lstset{#1}
}
{}