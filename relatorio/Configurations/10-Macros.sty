% Command to overwrite the color of a given command.
\newcommand{\overwritecolor}[2]{%
    \textcolor{#1}{%
        \renewcommand\color[2][]{}%
    #2}%
}

% Wrapping bot glossary and acronyms commands.
\newcommand{\printnormalglossary}{\printnoidxglossary[sort=word]}
\newcommand{\printacronymglossary}{%
    \chapter*{\acronymname}%
    \begin{longtable}{@{}p{0.15\textwidth} p{0.85\textwidth}@{}}
        \hypertarget{glo:api}{}\hypertarget{acr:api}{}\hypertarget{api}{\textbf{API}} & Application Programming Interface \\
        \hypertarget{glo:ast}{}\hypertarget{acr:ast}{}\hypertarget{ast}{\textbf{AST}} & Árvore de Sintaxe Abstrata (\textit{Abstract Syntax Tree}) \\
        \hypertarget{glo:bfs}{}\hypertarget{acr:bfs}{}\hypertarget{bfs}{\textbf{BFS}} & Pesquisa em Largura (\textit{Breadth-First Search}) \\
        \hypertarget{glo:csv}{}\hypertarget{acr:csv}{}\hypertarget{csv}{\textbf{CSV}} & Comma-Separated Values \\
        \hypertarget{glo:dag}{}\hypertarget{acr:dag}{}\hypertarget{dag}{\textbf{DAG}} & Grafo Direcionado Acíclico (\textit{Directed Acyclic Graph}) \\
        \hypertarget{glo:dfs}{}\hypertarget{acr:dfs}{}\hypertarget{dfs}{\textbf{DFS}} & Pesquisa em Profundidade (\textit{Depth-First Search}) \\
        \hypertarget{glo:estg}{}\hypertarget{acr:estg}{}\hypertarget{estg}{\textbf{ESTG}} & Escola Superior de Tecnologia e Gestão \\
        \hypertarget{glo:fi}{}\hypertarget{acr:fi}{}\hypertarget{fi}{\textbf{FI}} & Ficção Interativa \\
        \hypertarget{glo:iftf}{}\hypertarget{acr:iftf}{}\hypertarget{iftf}{\textbf{IFTF}} & Interactive Fiction Technology Foundation \\
        \hypertarget{glo:json}{}\hypertarget{acr:json}{}\hypertarget{json}{\textbf{JSON}} & JavaScript Object Notation \\
        \hypertarget{glo:piap}{}\hypertarget{acr:piap}{}\hypertarget{piap}{\textbf{PiaP}} & Plot in a Pot \\
        \hypertarget{glo:regex}{}\hypertarget{acr:regex}{}\hypertarget{regex}{\textbf{Regex}} & Expressões Regulares \\
        \hypertarget{glo:spa}{}\hypertarget{acr:spa}{}\hypertarget{spa}{\textbf{SPA}} & Single Page Application \\
    \end{longtable}%
}
\newcommand{\printsymbolglossary}{\printnoidxglossary[type=symbols, sort=word]}

% Logic to add or omit a blank page depending on the '\MediaOption' value.
\newcommand{\MediaOptionLogic}{%
    \ifthenelse{\equal{\MediaOption}{paper}}{\plainblankpage}{\thispagestyle{plain}}%
}

\newcommand{\MediaOptionLogicAcr}{%
    \ifthenelse{\equal{\MediaOption}{paper}}{\plainblankpage}{\clearpage\thispagestyle{plain}}%
}

\newcommand{\MediaOptionLogicBlank}{%
    \ifthenelse{\equal{\MediaOption}{paper}}{\blankpage}{}%
}

\newcommand{\MediaOptionLogicAnnexes}{%
    \ifthenelse{\equal{\MediaOption}{paper}}{\blankpage}{\clearpage}%
}

% Update various elements based on the '\MediaOption' value.
\apptocmd{\tableofcontents}{\MediaOptionLogic}{}{\fail}
\apptocmd{\listoffigures}{\MediaOptionLogic}{}{\fail}
\apptocmd{\listoftables}{\MediaOptionLogic}{}{\fail}
\apptocmd{\printnormalglossary}{\MediaOptionLogic}{}{\fail}
\apptocmd{\printacronymglossary}{\MediaOptionLogicAcr}{}{\fail}
\apptocmd{\printsymbolglossary}{\MediaOptionLogicAcr}{}{\fail}
\pretocmd{\printbibliography}{\MediaOptionLogic}{}{\fail}

\NewDocumentCommand{\prompt}{o m}{%
    \ifthenelse{\equal{\LanguageOption}{portuguese}}{%
        \IfNoValueTF{#1}
        {\noindent\textbf{Instrução:} #2}
        {\noindent\textbf{Instrução #1:} #2}
    }{\ifthenelse{\equal{\LanguageOption}{spanish}}{%
        \IfNoValueTF{#1}
        {\noindent\textbf{Instrucción:} #2}
        {\noindent\textbf{Instrucción #1:} #2}
    }{
        \IfNoValueTF{#1}
        {\noindent\textbf{Prompt:} #2}
        {\noindent\textbf{Prompt #1:} #2}
    }}
}

\NewDocumentCommand{\aioutput}{o m}{%
    \ifthenelse{\equal{\LanguageOption}{portuguese}}{%
        \IfNoValueTF{#1}
        {\noindent\textbf{Resposta:} #2}
        {\noindent\textbf{Resposta #1:} #2}
    }{\ifthenelse{\equal{\LanguageOption}{spanish}}{%
        \IfNoValueTF{#1}
        {\noindent\textbf{Respuesta:} #2}
        {\noindent\textbf{Respuesta #1:} #2}
    }{
        \IfNoValueTF{#1}
        {\noindent\textbf{Output:} #2}
        {\noindent\textbf{Output #1:} #2}
    }}
}